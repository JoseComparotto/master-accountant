{
    "name": "@repo/contracts",
    "type": "module",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "dev": "concurrently \"tsc --watch\" \"npm run dev:spec\"",
        "build": "tsc && npm run build:spec",
        "dev:spec": "tsx --watch ./scripts/generate-spec.js",
        "build:spec": "tsx ./scripts/generate-spec.js",
        "lint": "eslint . --max-warnings 0",
        "check-types": "tsc --noEmit",
        "generate-barrels": "node ../../tools/generate-barrels.js"
    },
    "dependencies": {
        "@anatine/zod-openapi": "^2.2.8",
        "@repo/core": "workspace:*",
        "@ts-rest/core": "^3.52.1",
        "@ts-rest/open-api": "^3.52.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@repo/typescript-config": "workspace:*",
        "@types/node": "^25.9.2",
        "concurrently": "^10.0.3",
        "typescript": "^6.0.3"
    }
}